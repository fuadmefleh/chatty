# Copy this file to .env and fill in your own values.

# --- Core LLM ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=
TEMPERATURE=0.7
MAX_ITERATIONS=5
MAX_MEMORY_TOKENS=4000

# --- Chat provider ---
CHAT_PROVIDER=telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_PHONE_NUMBER=your_phone_number_here
WEB_USER_ID=
CHATTY_WEB_API_KEY=

# --- Skills ---
SKILLS_DIR=skills
MEMORY_DIR=memory

# --- Gmail skill ---
# Requires skills/gmail/credentials.json (Google Cloud OAuth client) — see skills/gmail/gmail.md

# --- SearXNG web search (self-hosted, no API key/quota) ---
# Point this at any SearXNG instance with JSON output enabled. If you don't
# already have one, `docker compose up -d searxng` (see docker-compose.yml)
# stands one up on port 8090.
SEARXNG_BASE_URL=http://localhost:8081

# --- Plaid / RocketMoney skill ---
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox

# --- Heartbeat (background task scheduler) ---
HEARTBEAT_FILE=
HEARTBEAT_INTERVAL_MINUTES=

# --- World Watch (proactive topic monitoring, part of the heartbeat) ---
WORLD_WATCH_INTERVAL_HOURS=24
STOCK_WATCH_INTERVAL_HOURS=4
GITHUB_WATCH_INTERVAL_HOURS=12
STOCK_WATCH_MOVE_THRESHOLD_PERCENT=5.0

# --- Memory-driven watch suggestions (part of the heartbeat) ---
MEMORY_SUGGESTION_INTERVAL_HOURS=168

# --- Daily Briefing (part of the heartbeat) ---
DAILY_BRIEFING_HOUR=8
HOME_LOCATION=

# --- Self-Upgrade (Chatty proposes and implements improvements to its own
# codebase, part of the heartbeat). Each idea runs in an isolated git
# worktree/branch and is only merged + auto-restarted if tests pass and main
# has no uncommitted changes - failed attempts leave the branch for review.
# SELF_UPGRADE_WORKTREES_DIR is optional - defaults to a sibling directory of
# the repo (../chatty_self_upgrade_worktrees) if left unset entirely (do not
# set it to an empty string - that resolves to the current directory).
SELF_UPGRADE_INTERVAL_HOURS=168
SELF_UPGRADE_TEST_TIMEOUT_SECONDS=300
