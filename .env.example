# Copy this file to .env and fill in your own values.

# --- Core LLM ---
# CHAT_PROVIDER selects which backend answers completions for both the
# Telegram bot and the web dashboard: "openai" (default), "local" (any
# OpenAI-compatible server, e.g. llama.cpp), or "anthropic" (Claude API).
CHAT_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
TEMPERATURE=0.7
MAX_ITERATIONS=5
MAX_MEMORY_TOKENS=4000

# --- Messaging / dashboard ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_PHONE_NUMBER=your_phone_number_here
WEB_USER_ID=
CHATTY_WEB_API_KEY=

# --- Speech-to-text (used by the iOS-companion audio ingestion endpoint,
# POST /api/chatty/audio; the Telegram bot has no voice-message handling) ---
# STT_PROVIDER selects the transcription backend:
#   whisperx_http (default) - external WhisperX HTTP server, with speaker
#     diarization + voice embeddings for the speaker-roster auto-labeling
#     feature (see skills/speakers/). Requires a WhisperX server running
#     separately (not included) at STT_ENGINE_URL.
#   openai - OpenAI's transcription API (whisper-1 or gpt-4o-transcribe).
#     No diarization/speaker embeddings.
#   local_whisper - in-process faster-whisper, no external server or API
#     key needed, but a heavier local dependency and no diarization.
#     Requires `pip install -r requirements-local-stt.txt`.
STT_PROVIDER=whisperx_http
STT_ENGINE_URL=http://127.0.0.1:8003
STT_OPENAI_MODEL=whisper-1
STT_LOCAL_MODEL_SIZE=base
STT_LOCAL_DEVICE=cpu

# --- Speaker identification (voice roster for labeling diarized transcripts) ---
# Cosine-similarity threshold (0-1) a voice embedding must clear to auto-match
# a known speaker. Tune based on observed same-person vs different-person
# score gaps for your embedding model/mic setup - see skills/speakers/speaker_manager.py.
SPEAKER_MATCH_THRESHOLD=0.6

# --- Skills ---
SKILLS_DIR=skills
MEMORY_DIR=memory

# --- Gmail skill ---
# Requires skills/gmail/credentials.json (Google Cloud OAuth client) — see skills/gmail/gmail.md

# --- SearXNG web search (self-hosted, no API key/quota) ---
# Point this at any SearXNG instance with JSON output enabled. If you don't
# already have one, `docker compose up -d searxng` (see docker-compose.yml)
# stands one up on port 8090.
SEARXNG_BASE_URL=http://localhost:8081

# --- Plaid / RocketMoney skill ---
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox

# --- Heartbeat (background task scheduler) ---
HEARTBEAT_FILE=
HEARTBEAT_INTERVAL_MINUTES=

# --- World Watch (proactive topic monitoring, part of the heartbeat) ---
WORLD_WATCH_INTERVAL_HOURS=24
STOCK_WATCH_INTERVAL_HOURS=4
GITHUB_WATCH_INTERVAL_HOURS=12
STOCK_WATCH_MOVE_THRESHOLD_PERCENT=5.0

# --- Memory-driven watch suggestions (part of the heartbeat) ---
MEMORY_SUGGESTION_INTERVAL_HOURS=168

# --- Daily Briefing (part of the heartbeat) ---
DAILY_BRIEFING_HOUR=8
HOME_LOCATION=

# --- Self-Upgrade (Chatty proposes and implements improvements to its own
# codebase, part of the heartbeat). Each idea runs in an isolated git
# worktree/branch and is only merged + auto-restarted if tests pass and main
# has no uncommitted changes - failed attempts leave the branch for review.
# SELF_UPGRADE_WORKTREES_DIR is optional - defaults to a sibling directory of
# the repo (../chatty_self_upgrade_worktrees) if left unset entirely (do not
# set it to an empty string - that resolves to the current directory).
SELF_UPGRADE_INTERVAL_HOURS=168
SELF_UPGRADE_TEST_TIMEOUT_SECONDS=300
SELF_UPGRADE_MAX_TEST_ATTEMPTS=3

# --- Trending Suggestions (Chatty scans GitHub trending repos and curates a
# menu of ideas, part of the heartbeat). Unlike Self-Upgrade, these are never
# implemented automatically - reviewed and chosen by hand on the dashboard.
TRENDING_LANGUAGES=python,typescript,javascript
TRENDING_SCAN_INTERVAL_HOURS=6
TRENDING_REPOS_PER_LANGUAGE=10
TRENDING_MAX_SUGGESTIONS_PER_SCAN=4
