# Copy this file to .env and fill in your own values.

# --- Core LLM ---
# CHAT_PROVIDER selects which backend answers completions for both the
# Telegram bot and the web dashboard: "openai" (default), "local" (any
# OpenAI-compatible server, e.g. llama.cpp), or "anthropic" (Claude API).
CHAT_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_API_KEY is also used directly (regardless of CHAT_PROVIDER) by the
# image_generation skill, which always calls OpenAI's gpt-image-1 model - no
# separate key/config needed.
# If CHAT_PROVIDER=local, point this at your own OpenAI-compatible server
# (e.g. llama.cpp, a LAN machine, etc) - the localhost default in
# src/core/config.py is just a placeholder. Under Docker Compose, if that
# server is itself another container on the stack, use its service name
# instead, e.g. http://llama-server:8080/v1.
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
TEMPERATURE=0.7
MAX_ITERATIONS=5
MAX_MEMORY_TOKENS=4000

# --- Messaging / dashboard ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_PHONE_NUMBER=your_phone_number_here
WEB_USER_ID=
CHATTY_WEB_API_KEY=
# Port chatty_web_server.py's uvicorn binds to. Under Docker Compose, change
# this alongside the "8016:8016" port mapping in docker-compose.yml if you
# customize it.
CHATTY_WEB_PORT=8016

# --- WhatsApp (whatsapp-bridge/ Node sidecar - see that folder's README) ---
# whatsapp-bridge holds the live Baileys/WhatsApp Web session; the Python
# backend only talks to it over this local HTTP API. WHATSAPP_BRIDGE_SECRET
# must match the same-named var in whatsapp-bridge's own environment - it's
# the only thing gating an API that can read messages and send them on the
# user's behalf, so pick a long random value.
WHATSAPP_BRIDGE_URL=http://127.0.0.1:8017
WHATSAPP_BRIDGE_SECRET=
# Hard per-chat daily cap on autonomous auto-replies (see
# skills/whatsapp_messages/whatsapp_managed_chats.py and heartbeat_manager.py's
# _process_whatsapp_managed_chats) - a safety valve, independent of the
# model's own judgement, against a runaway reply loop spamming a contact.
WHATSAPP_AUTO_REPLY_DAILY_LIMIT=20

# --- LinkedIn (skills/linkedin_messages/ - unofficial, read-only) ---
# No env var here - LinkedIn grants no third-party API access to personal
# messaging/feed/connections, so there's no OAuth client secret to configure.
# The session is a `li_at` + JSESSIONID cookie pair the user pastes on the
# dashboard's Settings page (captured from their own logged-in browser),
# stored in data/linkedin_session.json. See linkedin_client.py's docstring
# for the ToS/risk callout on this approach.

# --- Speech-to-text (used by the iOS-companion audio ingestion endpoint,
# POST /api/chatty/audio; the Telegram bot has no voice-message handling) ---
# STT_PROVIDER selects the transcription backend:
#   whisperx_http (default) - external WhisperX HTTP server, with speaker
#     diarization + voice embeddings for the speaker-roster auto-labeling
#     feature (see skills/speakers/). Requires a WhisperX server running
#     separately (not included) at STT_ENGINE_URL.
#   openai - OpenAI's transcription API (whisper-1 or gpt-4o-transcribe).
#     No diarization/speaker embeddings.
#   local_whisper - in-process faster-whisper, no external server or API
#     key needed, but a heavier local dependency and no diarization.
#     Requires `pip install -r requirements-local-stt.txt`.
#   parakeet - external parakeet-server (github.com/mudler/parakeet.cpp), a
#     small OpenAI-compatible transcription server for NVIDIA's Parakeet
#     ASR models. No diarization/speaker embeddings. Run parakeet-server
#     separately (not included) at STT_PARAKEET_URL.
STT_PROVIDER=whisperx_http
# In Docker Compose with the optional `whisperx` profile enabled
# (docker compose --profile whisperx up -d), point this at the service name
# instead: STT_ENGINE_URL=http://whisperx:8003
STT_ENGINE_URL=http://127.0.0.1:8003
STT_OPENAI_MODEL=whisper-1
STT_LOCAL_MODEL_SIZE=base
STT_LOCAL_DEVICE=cpu
# Base URL must include the /v1 path, e.g. http://127.0.0.1:8011/v1
STT_PARAKEET_URL=http://127.0.0.1:8011/v1
STT_PARAKEET_MODEL=parakeet

# --- Text-to-speech (Telegram bot replies with a voice message via the
# speak_text skill, skills/tts/) ---
# TTS_PROVIDER selects the backend:
#   local (default) - the tts_engine_api microservice already running on
#     this host (kokoro/mms/chatterbox engines). No API key needed.
#   elevenlabs - ElevenLabs API. Requires ELEVENLABS_API_KEY.
#   openai - OpenAI's audio.speech API. Reuses OPENAI_API_KEY above.
TTS_PROVIDER=local
TTS_LOCAL_ENGINE_URL=http://127.0.0.1:8002
TTS_LOCAL_ENGINE_ENGINE=kokoro
TTS_LOCAL_ENGINE_VOICE=af_sky
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# --- Speaker identification (voice roster for labeling diarized transcripts) ---
# Cosine-similarity threshold (0-1) a voice embedding must clear to auto-match
# a known speaker. Tune based on observed same-person vs different-person
# score gaps for your embedding model/mic setup - see skills/speakers/speaker_manager.py.
SPEAKER_MATCH_THRESHOLD=0.6

# --- Skills ---
SKILLS_DIR=skills
MEMORY_DIR=memory

# --- Gmail skill ---
# Requires skills/gmail/credentials.json (Google Cloud OAuth client) — see skills/gmail/gmail.md

# --- SearXNG web search (self-hosted, no API key/quota) ---
# Point this at any SearXNG instance with JSON output enabled. If you don't
# already have one, `docker compose --profile searxng up -d` (see
# docker-compose.yml) stands one up on port 8090. In Docker Compose with that
# profile enabled, point this at the service name instead:
# SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_BASE_URL=http://localhost:8081

# --- Plaid / RocketMoney skill ---
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox

# --- Heartbeat (background task scheduler) ---
HEARTBEAT_FILE=
HEARTBEAT_INTERVAL_MINUTES=

# --- World Watch (proactive topic monitoring, part of the heartbeat) ---
WORLD_WATCH_INTERVAL_HOURS=24
STOCK_WATCH_INTERVAL_HOURS=4
GITHUB_WATCH_INTERVAL_HOURS=12
STOCK_WATCH_MOVE_THRESHOLD_PERCENT=5.0

# --- Memory-driven watch suggestions (part of the heartbeat) ---
MEMORY_SUGGESTION_INTERVAL_HOURS=168

# --- Daily Briefing (part of the heartbeat) ---
DAILY_BRIEFING_HOUR=8
HOME_LOCATION=

# --- Self-Upgrade (Atlas proposes and implements improvements to its own
# codebase, part of the heartbeat). Each idea runs in an isolated git
# worktree/branch and is only merged + auto-restarted if tests pass and main
# has no uncommitted changes - failed attempts leave the branch for review.
# SELF_UPGRADE_WORKTREES_DIR is optional - defaults to a sibling directory of
# the repo (../chatty_self_upgrade_worktrees) if left unset entirely (do not
# set it to an empty string - that resolves to the current directory). In
# Docker Compose this is set to /worktrees (a bind mount of that same host
# sibling directory) by docker-compose.yml's `environment:` block - no action
# needed here unless you're running outside Compose.
SELF_UPGRADE_INTERVAL_HOURS=168
SELF_UPGRADE_TEST_TIMEOUT_SECONDS=300
SELF_UPGRADE_MAX_TEST_ATTEMPTS=3
# Directory the restart-signal mechanism (replacing pm2 under Docker) writes
# to; polled by the `restarter` sidecar container in docker-compose.yml.
# Defaults to ./restart_requests under the repo root - only override if you
# changed the sidecar's mount path.
RESTART_REQUESTS_DIR=

# --- Coding agents (used by Self-Upgrade above, and by the dashboard's
# manual "feature request" queue) ---
# opencode (https://opencode.ai/) is installed via `npm install -g
# opencode-ai` in the Docker image - leave OPENCODE_BIN unset to use the
# image's global install.
OPENCODE_BIN=
# pi (https://pi.dev/) has no public install package - the Docker image
# reserves /opt/pi-bin on PATH as a mount point for your own `pi` binary (see
# docker-compose.yml's ./docker/pi-bin and ./docker/pi-config mounts). Leave
# unset if you don't have access to `pi`; requests routed to it fail
# gracefully with "Pi binary not found" rather than crashing.
PI_BIN=
PI_AGENT_PROVIDER=llama-cpp
PI_AGENT_MODEL=qwen3.6-27b

# --- Trending Suggestions (Atlas scans GitHub trending repos and curates a
# menu of ideas, part of the heartbeat). Unlike Self-Upgrade, these are never
# implemented automatically - reviewed and chosen by hand on the dashboard.
TRENDING_LANGUAGES=python,typescript,javascript
TRENDING_SCAN_INTERVAL_HOURS=6
TRENDING_REPOS_PER_LANGUAGE=10
TRENDING_MAX_SUGGESTIONS_PER_SCAN=4

# --- Webcam Discovery (Atlas searches via SearXNG for promising public
# live-webcam pages/threads and curates best-effort suggestions, part of the
# heartbeat). Reviewed and approved by hand on the dashboard's /webcams page.
WEBCAM_DISCOVERY_QUERIES=site:reddit.com live traffic camera;site:reddit.com earthcam;live webcam city traffic feed;DOT traffic camera portal live view;live streaming webcam tourist attraction
WEBCAM_DISCOVERY_INTERVAL_HOURS=12
WEBCAM_DISCOVERY_RESULTS_PER_QUERY=8
WEBCAM_DISCOVERY_MAX_SUGGESTIONS_PER_SCAN=5

# ── Notes by Atlas (chatty-notes-api sidecar) ────────────────────────────────
# Bearer token for the agent-scoped blog API (chatty-notes-api Docker sidecar).
# The autonomous blog writer creates review drafts; nothing publishes without a
# human approve action on the dashboard's /chatty-blog page. Leave AGENT_API_TOKEN
# empty to disable the writer entirely.
AGENT_API_TOKEN=
AGENT_TAG=chatty-notes
BLOG_API_URL=http://127.0.0.1:3210
BLOG_WRITE_INTERVAL_HOURS=72
