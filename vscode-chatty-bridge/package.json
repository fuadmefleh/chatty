{
  "name": "chatty-bridge",
  "displayName": "Atlas Bridge",
  "description": "Bridge between Atlas Telegram bot and VS Code Copilot agent. Receives code change requests from Telegram and sends them to Copilot.",
  "version": "1.0.0",
  "publisher": "atlas",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chatty-bridge.checkNow",
        "title": "Atlas Bridge: Check for Requests"
      },
      {
        "command": "chatty-bridge.completeRequest",
        "title": "Atlas Bridge: Mark Current Request Completed"
      },
      {
        "command": "chatty-bridge.failRequest",
        "title": "Atlas Bridge: Mark Current Request Failed"
      },
      {
        "command": "chatty-bridge.togglePolling",
        "title": "Atlas Bridge: Toggle Auto-Polling"
      },
      {
        "command": "chatty-bridge.showQueue",
        "title": "Atlas Bridge: Show Request Queue"
      }
    ],
    "configuration": {
      "title": "Atlas Bridge",
      "properties": {
        "chattyBridge.apiUrl": {
          "type": "string",
          "default": "http://localhost:5001",
          "description": "URL of the Atlas mini app server"
        },
        "chattyBridge.pollInterval": {
          "type": "number",
          "default": 10,
          "description": "Polling interval in seconds"
        },
        "chattyBridge.autoSend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically send requests to Copilot (true) or show confirmation first (false)"
        },
        "chattyBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic polling for new requests"
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0"
  }
}
